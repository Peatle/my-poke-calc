{
  "name": "my-poke-calc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "data:fetch-names": "node scripts/fetchNames.js",
    "data:fetch-stats": "node scripts/fetchStats.js",
